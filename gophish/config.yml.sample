openaev:
  url: 'http://localhost:3001'
  token: 'ChangeMe'
# tenant_id: 'ChangeMe'

injector:
  id: 'ChangeMe'
  name: 'Gophish'
  log_level: 'error'

gophish:
  base_url: 'https://localhost:3333'
  api_key: 'ChangeMe'
  # Verify the Gophish server TLS certificate (secure by default).
  # Set to false only for self-signed or local development servers.
  verify_tls: true
