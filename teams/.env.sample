# OPENAEV Environment Variables
# base URL to reach the OpenAEV server
# note this URL must be routable from inside the container
# so `localhost` will most likely not work
OPENAEV_URL=ChangeMe
# admin account API token from the OpenAEV server
OPENAEV_TOKEN=ChangeMe

# INJECTOR Environment Variables
INJECTOR_ID=msteams--ChangeMe
INJECTOR_NAME="Microsoft Teams"
INJECTOR_LOG_LEVEL=error

# MICROSOFT TEAMS / GRAPH Environment Variables
# Microsoft Entra ID (Azure AD) app registration - see the README for the setup.
TEAMS_TENANT_ID=ChangeMe
TEAMS_CLIENT_ID=ChangeMe
TEAMS_CLIENT_SECRET=ChangeMe
# Long-lived refresh token minted by the one-time admin consent (see the README).
TEAMS_REFRESH_TOKEN=ChangeMe
# Optional overrides (defaults shown):
# TEAMS_AUTHORITY_BASE_URL=https://login.microsoftonline.com
# TEAMS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
# TEAMS_SCOPE=offline_access ChannelMessage.Send ChatMessage.Send
# TEAMS_REQUEST_TIMEOUT_SECONDS=30
