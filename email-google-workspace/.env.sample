# OPENAEV Environment Variables
# base URL to reach the OpenAEV server
# note this URL must be routable from inside the container
# so `localhost` will most likely not work
OPENAEV_URL=ChangeMe
# admin account API token from the OpenAEV server
OPENAEV_TOKEN=ChangeMe
OPENAEV_TENANT_ID=ChangeMe

# INJECTOR Environment Variables
INJECTOR_ID=email-google-workspace--ChangeMe
INJECTOR_NAME="Email (Google Workspace)"
INJECTOR_LOG_LEVEL=error

# GOOGLE WORKSPACE Environment Variables
# Full service account key JSON (single line) with domain-wide delegation for gmail.send - see the README.
GWS_SERVICE_ACCOUNT_JSON=ChangeMe
# Optional overrides (defaults shown):
# GWS_GMAIL_BASE_URL=https://gmail.googleapis.com/gmail/v1
# GWS_REQUEST_TIMEOUT_SECONDS=30
