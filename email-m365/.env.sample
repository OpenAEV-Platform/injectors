# OPENAEV Environment Variables
# base URL to reach the OpenAEV server
# note this URL must be routable from inside the container
# so `localhost` will most likely not work
OPENAEV_URL=ChangeMe
# admin account API token from the OpenAEV server
OPENAEV_TOKEN=ChangeMe
OPENAEV_TENANT_ID=ChangeMe

# INJECTOR Environment Variables
# Replace with a unique UUIDv4 for this injector instance.
INJECTOR_ID=00000000-0000-4000-8000-000000000000
INJECTOR_NAME="Email (Microsoft 365)"
INJECTOR_LOG_LEVEL=error

# MICROSOFT 365 Environment Variables
# Entra ID (Azure AD) app registration with the Mail.Send application permission - see the README.
M365_TENANT_ID=ChangeMe
M365_CLIENT_ID=ChangeMe
M365_CLIENT_SECRET=ChangeMe
# Optional overrides (defaults shown):
# M365_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
# M365_AUTHORITY_BASE_URL=https://login.microsoftonline.com
# M365_REQUEST_TIMEOUT_SECONDS=30
